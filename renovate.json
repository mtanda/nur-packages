{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "lockFileMaintenance": {
    "enabled": true,
    "extends": ["schedule:daily"]
  },
  "automerge": true,
  "gitIgnoredAuthors": [
    "41898282+github-actions[bot]@users.noreply.github.com"
  ],
  "automergeStrategy": "rebase",
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["nvfetcher\\.toml$"],
      "matchStrings": [
        "\\[(?<depName>[^\\]]+)\\]\\nfetch\\.github\\s*=\\s*\"(?<packageName>[^\"]+)\"\\nsrc\\.manual\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["nvfetcher\\.toml$"],
      "matchStrings": [
        "\\[(?<depName>[^\\]]+)\\]\\nfetch\\.url\\s*=\\s*\"https://registry\\.npmjs\\.org/(?<packageName>[^/]+)/[^\"]+\"\\nsrc\\.manual\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["pkgs/.*/sources\\.json$"],
      "matchStrings": [
        "\"repo\":\\s*\"(?<depName>[^\"]+)\"[\\s\\S]*?\"tag\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
